---
import InstagramIcon from "../assets/instagram.svg";
import SectionContainer from "../components/SectionContainer.astro";
---

<SectionContainer title="Galería" subtitle="Nuestra comida" name="galeria">
  <div
    class="grid grid-cols-2 md:grid-cols-5 grid-rows-7 md:grid-rows-4 gap-6 md:gap-4 [&>div]:rounded-lg [&>div]:overflow-hidden"
  >
    <div
      class="md:row-span-2 col-span-2 md:col-span-1 flex flex-col justify-center items-center md:items-start"
    >
      <InstagramIcon class="size-12 rounded-full bg-red-400 p-2 mb-4" />
      <h2 class="xl:text-4xl text-2xl font-bold">SÍGUENOS</h2>
      <a
        class="xl:text-4xl text-2xl font-bold hover:text-red-400 uppercase transition-colors"
        href="https://www.instagram.com/ehomakis_lima/"
        target="_blank"
        rel="noopener noreferrer"
      >@ehomakis</a
      >
    </div>
    <div class="row-span-2 md:col-start-1 row-start-2 md:row-start-3">
      <img src="/images/galery/makis-1.webp" alt="Presentacion Langostinos" loading="lazy" width="640" height="480" />
    </div>
    <div class="row-span-4 col-start-2 row-start-4 md:row-start-1">
      <img src="/images/galery/vertical-1.webp" alt="Combo especial" loading="lazy" width="480" height="640" />
    </div>
    <div
      class="md:row-span-2 row-span-2 md:col-start-3 row-start-2 md:row-start-1"
    >
      <img src="/images/galery/makis-2.webp" alt="Bento con makis" loading="lazy" width="640" height="480" />
    </div>
    <div
      class="row-span-2 col-start-1 md:col-start-3 row-start-4 md:row-start-3"
    >
      <img src="/images/galery/makis-3.webp" alt="Makis Furai" loading="lazy" width="640" height="480" />
    </div>
    <div class="row-span-4 col-start-4 row-start-1 hidden md:block">
      <img src="/images/galery/vertical-2.webp" alt="Makis Makizushi" loading="lazy" width="480" height="640" />
    </div>
    <div class="row-span-2 md:col-start-5 md:row-start-1 row-start-6">
      <img src="/images/galery/makis-4.webp" alt="Makis Temaki" loading="lazy" width="640" height="480" />
    </div>
    <div class="row-span-2 col-start-5 row-start-3 hidden md:block">
      <img src="/images/galery/makis-5.webp" alt="Makis Futomaki" loading="lazy" width="640" height="480" />
    </div>
  </div>
</SectionContainer>

<style>
  img {
    transition: transform 0.4s;
    object-fit: cover;
    width: 100%;
    height: 100%;
  }
  img:hover {
    transform: scale(1.05);
  }
</style>
