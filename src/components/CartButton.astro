---
import CartIcon from "../assets/icons/cart.svg";
---

<button type="button" aria-label="Abrir carrito" class="cart-btn backdrop-blur-md" id="openCart">
  <div class="relative">
    <CartIcon class="size-7 md:size-8" />
  </div>
  <span class="cart-count" id="cartCount">0</span>
</button>
<style>
  .cart-btn {
    position: fixed;
    bottom: 3.5rem;
    right: 1.5rem;
    border: 1px solid var(--gold);
    border-radius: 100%;
    color: var(--gold);
    font-family: "DM Sans", sans-serif;
    padding: 0.65rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    cursor: pointer;
    transition: all 0.2s;
    display: flex;
    align-items: center;
    z-index: 20;
    @media (min-width: 768px) {
      padding: 0.75rem;
    }
  }
  .cart-btn:hover {
    background: var(--gold);
    color: var(--black);
  }
  .cart-count {
    position: absolute;
    top: -8px;
    right: -8px;
    background: var(--red);
    color: white;
    border-radius: 50%;
    width: 25px;
    height: 25px;
    font-size: 0.75rem;
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: 600;
  }
</style>

<script>
  const initCartButton = () => {
    const cartOverlay = document.getElementById("cartOverlay");
    const cartDrawer = document.getElementById("cartDrawer");
    const openCart = document.getElementById("openCart");
    const closeCart = document.getElementById("closeCart");

    function toggleCart(open) {
      cartDrawer?.classList.toggle("open", open);
      cartOverlay?.classList.toggle("open", open);
      document.body.style.overflow = open ? "hidden" : "";
    }

    openCart?.addEventListener("click", () => toggleCart(true));
    closeCart?.addEventListener("click", () => toggleCart(false));
    cartOverlay?.addEventListener("click", () => toggleCart(false));
  };

  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", initCartButton);
  } else {
    initCartButton();
  }
</script>
