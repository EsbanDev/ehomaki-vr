---
const { item } = Astro.props;
---
<div
  class="menu-card"
  data-cat={item.category}
  data-id={item.id}
  data-name={item.name}
  data-price={item.price}
  data-img={item.image}
>
  <div class="card-img-wrap">
    <img
      class="card-img"
      src={item.image}
      alt={item.name}
      loading="lazy"
    />
    {item.badge && <span class="card-badge">{item.badge}</span>}
  </div>
  <div class="card-name">{item.name}</div>
  <div class="card-desc">
    {item.description}
  </div>
  <div class="card-footer">
    <div class="card-price">S/ {item.price} <span>/ {item.portion}</span></div>
    <button class="add-btn" title="Agregar al carrito">+</button>
  </div>
</div>

<style>
  .menu-card {
    background: var(--card);
    padding: 2rem;
    position: relative;
    overflow: hidden;
    transition: background 0.2s;
    display: block;
  }
  .menu-card.hidden {
    display: none;
  }

  .menu-card::before {
    content: "";
    position: absolute;
    top: 0;
    left: 0;
    width: 3px;
    height: 0;
    background: var(--gold);
    transition: height 0.3s;
  }
  .menu-card:hover::before {
    height: 100%;
  }
  .menu-card:hover {
    background: #1c1810;
  }

  .card-img-wrap {
    width: 100%;
    aspect-ratio: 4/3;
    overflow: hidden;
    margin-bottom: 1.25rem;
    position: relative;
  }
  .card-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.5s;
    filter: saturate(0.85);
  }
  .menu-card:hover .card-img {
    transform: scale(1.06);
    filter: saturate(1);
  }

  .card-badge {
    position: absolute;
    top: 0.75rem;
    right: 0.75rem;
    background: var(--red);
    color: white;
    font-size: 0.6rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    padding: 0.2rem 0.6rem;
  }

  .card-name {
    font-family: "Noto Serif JP", serif;
    font-size: 1rem;
    font-weight: 700;
    margin-bottom: 0.5rem;
    color: var(--white);
  }
  .card-desc {
    font-size: 0.75rem;
    color: var(--muted);
    line-height: 1.6;
    margin-bottom: 1.25rem;
  }
  .card-footer {
    display: flex;
    justify-content: space-between;
    align-items: center;
  }
  .card-price {
    font-family: "Bebas Neue", sans-serif;
    font-size: 1.5rem;
    color: var(--gold);
  }
  .card-price span {
    font-family: "DM Sans", sans-serif;
    font-size: 0.7rem;
    color: var(--muted);
  }
  .add-btn {
    background: none;
    border: 1px solid var(--border);
    color: var(--muted);
    width: 36px;
    height: 36px;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    font-size: 1.25rem;
    transition: all 0.2s;
    line-height: 1;
  }
  .add-btn:hover {
    border-color: var(--gold);
    color: var(--gold);
    background: rgba(201, 151, 58, 0.08);
  }
  .add-btn.added {
    background: var(--gold);
    border-color: var(--gold);
    color: var(--black);
  }
</style>